{
  "compilerOptions": {
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "sourceMap": false,
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "useUnknownInCatchVariables": false,
    "types": [
      "node"
    ]
  },
  "include": ["actions", "bin", "commands", "lib"],
  "exclude": ["node_modules", "e2e"]
}
